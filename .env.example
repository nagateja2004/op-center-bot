GROQ_API_KEY=
DOCUMENT_PARSER=pymupdf

GROQ_PLANNER_MODEL=llama-3.1-8b-instant
GROQ_PLANNER_FALLBACK_MODEL=openai/gpt-oss-20b
GROQ_GRADER_MODEL=openai/gpt-oss-20b
GROQ_GRADER_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_QUERY_MODEL=llama-3.1-8b-instant
GROQ_ANSWER_MODEL=llama-3.3-70b-versatile
GROQ_ANSWER_FALLBACK_MODEL=openai/gpt-oss-20b
GROQ_VERIFY_MODEL=openai/gpt-oss-20b
GROQ_VERIFY_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_DIAGRAM_MODEL=llama-3.1-8b-instant

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

CHROMA_DIRECTORY=indexes/chroma
BM25_INDEX_PATH=indexes/bm25.pkl
EVIDENCE_UNITS_PATH=indexes/evidence_units.json
RETRIEVAL_SEGMENTS_PATH=indexes/retrieval_segments.json
